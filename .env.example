# AgentVault Trading Bot Configuration
# Copy this to .env and fill in your values

# Network (testnet or mainnet)
NETWORK=testnet

# Your Hedera Account (get free testnet account at portal.hedera.com)
OPERATOR_ID=0.0.YOUR_ACCOUNT_ID
OPERATOR_KEY=302e...YOUR_PRIVATE_KEY

# Trading Settings
MAX_DAILY_SPEND=100
MAX_PER_TRADE=50
REQUIRE_APPROVAL_ABOVE=25

# Allowed Tokens (comma separated)
ALLOWED_TOKENS=HBAR,SAUCE,USDC

# Active Trading Hours (24h format)
ACTIVE_START_HOUR=9
ACTIVE_END_HOUR=17

# Strategy Settings
DEFAULT_SLIPPAGE=1
DEFAULT_GAS_LIMIT=300000