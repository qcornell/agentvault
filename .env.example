# AgentVault — Environment Variables
# Copy this to .env and fill in real values. NEVER commit .env to git.

# ─── Hedera Credentials ───
HEDERA_OPERATOR_ID=0.0.YOUR_ACCOUNT_ID
HEDERA_OPERATOR_KEY=302e...YOUR_ED25519_PRIVATE_KEY
HEDERA_NETWORK=mainnet

# ─── Dashboard Server ───
VAULT_DASHBOARD_PORT=3099
